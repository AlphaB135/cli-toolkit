{
  "name": "@alphaseed/cli-toolkit",
  "version": "1.0.0",
  "description": "Production-ready Node.js CLI template with TypeScript, testing, and best practices",
  "main": "dist/index.js",
  "bin": {
    "mycli": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "commander",
    "template",
    "boilerplate",
    "typescript",
    "cli-tool",
    "terminal"
  ],
  "author": "αB <https://github.com/AlphaB135>",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.12",
    "cli-table3": "^0.6.3",
    "conf": "^12.0.0",
    "update-notifier": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/inquirer": "^9.0.7",
    "@types/cli-table3": "^0.3.9",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1",
    "@vitest/coverage-v8": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
